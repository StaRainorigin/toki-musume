{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "toki-musume",
  "version": "0.1.0",
  "identifier": "com.tokimusume.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "toki-musume",
        "width": 800,
        "height": 600,
        "visible": true
      },
      {
        "label": "live2d",
        "title": "",
        "url": "live2d.html",
        "width": 300,
        "height": 500,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
